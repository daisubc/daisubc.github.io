# --- Open-source LLM via an OpenAI-compatible endpoint ---
#
# DEFAULT (safe + private): local Ollama. Email text never leaves your computer.
# You don't need to set anything here for local mode — just run Ollama (see README).
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1
LLM_API_KEY=

# --- Optional: cloud providers (faster, but email is sent to them) ---
# Groq:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=your_groq_key

# Together AI:
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# LLM_API_KEY=your_together_key

# --- CORS: where the frontend is served from ---
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
